" Enable syntax highlighting
syntax on

" Use 4 spaces for tabs
set expandtab
set tabstop=4
set shiftwidth=4

" Softwrap lines
set wrap
set linebreak
set nolist
set textwidth=0
set wrapmargin=0
set formatoptions+=1

" Show line numbers
set nu

" Disable arrow keys
map <up> <nop>
map <down> <nop>
map <left> <nop>
map <right> <nop>
imap <up> <nop>
imap <down> <nop>
imap <left> <nop>
imap <right> <nop>

