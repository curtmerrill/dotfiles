root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Trailing spaces are meaningful in Markdown
trim_trailing_whitespace = false

[*.py]
max_line_length = 88

[*.{html,json}]
indent_size = 2
trim_trailing_whitespace = false

[*.{css,js}]
indent_size = 2

# Ignore 3rd party JS files
[**/{lib,vendor}/**.js]
charset = ignore
end_of_line = ignore
indent_size = ignore
indent_style = ignore
trim_trailing_whitespace = ignore
